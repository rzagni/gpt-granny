{
  "manifest_version": 3,
  "name": "GPT Granny",
  "version": "1.1.0",
  "description": "Clean up your ChatGPT sidebar by selecting and deleting multiple recent chats at once",
  "permissions": ["scripting", "tabs", "activeTab"],
  "host_permissions": ["https://chatgpt.com/*"],
  "action": {
    "default_title": "GPT Granny",
    "default_popup": "granny.html"
  },
  "icons": {
    "128": "icons/128.png"
  }
}